# Supabase project settings — Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — bypasses Row Level Security. Never expose to the client, never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo notification sink. Leave unset to persist/log notifications only.
NOTIFICATION_WEBHOOK_URL=

# Gmail/Nodemailer transactional email (server-only).
# Google Account -> Security -> 2-Step Verification -> App passwords. Create a "Mail" password,
# then paste the generated 16 characters below (spaces are accepted and stripped at runtime).
# Never use your normal Google password and never prefix these variables with NEXT_PUBLIC_.
GMAIL_USER=emmapresheateryandlounge@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=EmmaPresh Eatery & Lounge
EMAIL_REPLY_TO=emmapresheateryandlounge@gmail.com
# Optional comma-separated BCC recipients for staff copies of customer emails.
EMAIL_ADMIN_RECIPIENTS=

# Google Search Console HTML-tag verification content (the value inside content="...").
GOOGLE_SITE_VERIFICATION=
